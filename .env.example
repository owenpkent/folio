# Folio environment variables (release / signing).
#
# Copy to `.env` (git-ignored) or set these directly in your shell before a
# *signed release build*. Day-to-day development (`npm run tauri dev`) needs
# NONE of these. Full release flow: docs/releasing.md.
#
# NOTE: Tauri does not auto-load `.env` for these — load them into your shell:
#   Git Bash:    set -a; . ./.env; set +a
#   PowerShell:  Get-Content .env | Where-Object { $_ -match '^\s*[^#].*=' } |
#                  ForEach-Object { $k,$v = $_ -split '=',2;
#                    [Environment]::SetEnvironmentVariable($k.Trim(), $v.Trim().Trim("'`"")) }

# Path to the minisign updater private key (Tauri also accepts the raw key
# contents here). The key file is itself password-protected. Typical location:
#   ~/.tauri/folio.key   (Windows: %USERPROFILE%\.tauri\folio.key)
# The matching public key (ID 95E10389C64A7469) is in src-tauri/tauri.conf.json.
TAURI_SIGNING_PRIVATE_KEY=

# Password for the minisign key (chosen at key generation). SENSITIVE.
# Prefer to leave this BLANK and enter it interactively at build time
# (PowerShell: `$env:TAURI_SIGNING_PRIVATE_KEY_PASSWORD = Read-Host 'Key password'`)
# or pull it from a password manager. `.env` is git-ignored but still plaintext
# on disk, so storing the release signing password here is discouraged.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
