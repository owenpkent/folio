{
  "manifest_version": 3,
  "name": "Folio PDF Viewer",
  "version": "0.1.0",
  "description": "Open PDFs in Folio's viewer in the browser, or hand off to the Folio desktop app.",
  "icons": { "128": "icons/icon-128.png" },
  "permissions": ["contextMenus", "declarativeNetRequest", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Open the current PDF in Folio (desktop)" },
  "web_accessible_resources": [{ "resources": ["dist/*"], "matches": ["<all_urls>"] }],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
