{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folio",
  "version": "0.1.0",
  "identifier": "app.folio.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Folio",
        "width": 1200,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "dragDropEnabled": true,
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://api.anthropic.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A world-class, open-source PDF viewer",
    "longDescription": "Folio is a fast, accessible, extensible, dark-mode-native PDF viewer.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/sign-windows.ps1 -Path %1"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/owenpkent/folio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4QThFRTI3QzNFNzQxMUQKUldRZFFlZkRKKzZvaUp6UVBmUW00QXZwOUd5MUFoVTNsNDVhRXphK1R1T3g4emoxek9UblhSNEYK"
    }
  }
}
